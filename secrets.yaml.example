# ============================================================================
#  Secrets — all personal/credential data lives here.
#  Copy this file to secrets.yaml and fill in your own values.
#  secrets.yaml is gitignored and must never be committed.
# ============================================================================

# Wi-Fi
wifi_ssid: "YOUR_WIFI_SSID"
wifi_password: "YOUR_WIFI_PASSWORD"

# Static IP configuration
ip_address: 192.168.1.50
gateway: 192.168.1.1
subnet: 255.255.255.0

# Over-the-air update password
ota_password: "choose-a-strong-ota-password"

# Optional: Home Assistant API encryption key.
# If you enable `api: encryption: key: !secret api_key` in dashboard.yaml,
# you must re-add the device in Home Assistant using this key.
api_key: "GENERATE_A_BASE64_KEY"
